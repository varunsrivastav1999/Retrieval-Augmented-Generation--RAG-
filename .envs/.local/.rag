# =============================================================================
# i-Tips RAG — Local Development Environment
# =============================================================================
# Uses Docker-based infrastructure with relaxed security for dev speed.
# =============================================================================

# General
# ------------------------------------------------------------------------------
USE_DOCKER=yes
RAG_ENV=local
RAG_CORS_ORIGINS=*

# Database (pgvector)
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://rag_user:rag_password@postgres:5432/rag_db

# Redis
# ------------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# Media
# ------------------------------------------------------------------------------
MEDIA_PATH=/media

# Ollama
# ------------------------------------------------------------------------------
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_MODEL=itips-brain
OLLAMA_TIMEOUT_SECONDS=600
OLLAMA_NUM_PREDICT=512

# GPU
# ------------------------------------------------------------------------------
RAG_MODEL_DEVICE=

# Hugging Face models
# ------------------------------------------------------------------------------
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_HF_OFFLINE=false
RAG_ALLOW_HASH_FALLBACK=true
RAG_ALLOW_RERANKER_FALLBACK=true
RAG_REQUIRE_REAL_MODELS=false
RAG_PRELOAD_MODELS_ON_STARTUP=true
RAG_ENABLE_INGESTION_WORKER=true

# Performance Tuning
# ------------------------------------------------------------------------------
RAG_DEFAULT_TOP_K=12
RAG_MAX_TOP_K=50
RAG_BROAD_QUERY_TOP_K=16
RAG_INGESTION_WORKER_POLL_SECONDS=3
RAG_CACHE_SEMANTIC_THRESHOLD=0.85
RAG_EMBEDDING_QUANTIZE=none
RAG_USE_HALFVEC=false

# Context Expansion
# ------------------------------------------------------------------------------
RAG_ENABLE_CONTEXT_EXPANSION=false
