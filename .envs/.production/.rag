# =============================================================================
# i-Tips RAG — Production Environment (EDIT THIS FILE WITH YOUR SECRETS)
# =============================================================================
# NEVER commit this file to version control with real passwords.
# On first deploy, replace default passwords with real secrets.
# =============================================================================

# General
USE_DOCKER=yes
RAG_ENV=production
RAG_CORS_ORIGINS=*

# Database (pgvector)
DATABASE_URL=postgresql://rag_user:rag_password@postgres:5432/rag_db

# Redis
REDIS_URL=redis://:mysecurepassword@redis:6379/0

# Media
MEDIA_PATH=/media

# Ollama
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_NUM_PREDICT=1024

# GPU — set to cpu to offload embedding/reranker to CPU, leave GPU for Ollama
RAG_MODEL_DEVICE=

# Hugging Face models
RAG_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RAG_EMBEDDING_DIM=1024
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_CLIP_MODEL=sentence-transformers/clip-ViT-L-14
RAG_HF_OFFLINE=false
RAG_ALLOW_HASH_FALLBACK=false
RAG_ALLOW_RERANKER_FALLBACK=false
RAG_REQUIRE_REAL_MODELS=true
RAG_PRELOAD_MODELS_ON_STARTUP=true
RAG_ENABLE_INGESTION_WORKER=true

# Performance Tuning
RAG_DEFAULT_TOP_K=6
RAG_MAX_TOP_K=50
RAG_BROAD_QUERY_TOP_K=16
RAG_INGESTION_WORKER_POLL_SECONDS=3
RAG_CACHE_SEMANTIC_THRESHOLD=0.85
RAG_EMBEDDING_QUANTIZE=int8
RAG_USE_HALFVEC=true

# Context Expansion
RAG_ENABLE_CONTEXT_EXPANSION=true
