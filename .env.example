# =============================================================================
# Enterprise Level RAG — Environment Variables Reference
# =============================================================================
# Copy relevant sections to .envs/.local/.rag or .envs/.production/.rag
# NEVER commit real passwords to version control.
#
# ── 16GB VRAM Budget (Optimized Stack) ───────────────────────────────────────
#  Component                  Model                        VRAM
#  ─────────────────────────────────────────────────────────────
#  LLM (Ollama, always-on)   qwen2.5:14b  Q4_K_M          ~8.5 GB
#  Embedding (HF, always-on) BAAI/bge-large-en-v1.5        ~1.3 GB
#  Reranker  (HF, always-on) BAAI/bge-reranker-v2-m3       ~1.2 GB
#  ─────────────────────────────────────────────────────────────
#  Subtotal (no vision)                                   ~11.0 GB
#  Headroom                                                ~5.0 GB
#  ─────────────────────────────────────────────────────────────
#  Vision (on-demand)        llama3.2-vision:11b           ~8.0 GB
#  (LLM unloads via KEEP_ALIVE=5m before vision loads)
#  Peak with vision (bge+reranker+vision, LLM unloaded)  ~10.5 GB
# =============================================================================

# ── General ───────────────────────────────────────────────────────────────────
USE_DOCKER=yes
RAG_ENV=local                    # local | production
RAG_CORS_ORIGINS=*                # Comma-separated origins or *

# ── Database (pgvector) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://rag_user:rag_password@postgres:5432/rag_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Media ─────────────────────────────────────────────────────────────────────
MEDIA_PATH=/media

# ── Ollama LLM ────────────────────────────────────────────────────────────────
# 16GB VRAM — Upgraded from llama3.1:8b (4.8GB) to qwen2.5:14b (8.5GB)
# qwen2.5:14b advantages for industrial RAG:
#   - Significantly better verbatim instruction following (critical for manuals)
#   - 128K native context window (more reliable at long context vs llama3.1:8b)
#   - Trained on larger technical/scientific corpus → fewer hallucinations on docs
#   - Better Chinese/multilingual technical term handling
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_MODEL=qwen2.5:14b                  # Upgraded from llama3.1:8b (~8.5GB VRAM)
OLLAMA_VISION_MODEL=llama3.2-vision:11b   # On-demand only; LLM unloads first via KEEP_ALIVE
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_CONTEXT_LENGTH=65536               # 64K — optimal for 16GB with q8_0 KV cache
OLLAMA_NUM_PREDICT=2048                   # Increased from 1024 for richer complete answers

# ── GPU ───────────────────────────────────────────────────────────────────────
RAG_MODEL_DEVICE=                # mps | cuda | cpu (blank = auto-detect)

# ── Hugging Face Models ───────────────────────────────────────────────────────
# 16GB VRAM — Upgraded embedding + reranker:
#
# EMBEDDING: bge-small-en-v1.5 (384d, ~150MB) → bge-large-en-v1.5 (1024d, ~1.3GB)
#   +41% MTEB score improvement; 1024d gives richer industrial-terminology coverage
#   IMPORTANT: After changing embedding model, you must re-ingest all documents
#              (different dimensions = incompatible vector indices)
#
# RERANKER: bge-reranker-base (~1.1GB) → bge-reranker-v2-m3 (~1.2GB)
#   State-of-the-art BEIR + MS-MARCO cross-encoder; multilingual; top MTEB score
#   Significantly better on domain-specific/technical text reranking
#
RAG_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5    # Upgraded from bge-small-en-v1.5
RAG_EMBEDDING_DIM=1024                         # Must match bge-large output dimension
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3    # Upgraded from bge-reranker-base
RAG_CLIP_MODEL=sentence-transformers/clip-ViT-L-14
RAG_HF_OFFLINE=false
RAG_ALLOW_HASH_FALLBACK=true
RAG_ALLOW_RERANKER_FALLBACK=true
RAG_REQUIRE_REAL_MODELS=false
RAG_PRELOAD_MODELS_ON_STARTUP=true
RAG_ENABLE_INGESTION_WORKER=true

# ── Performance Tuning ────────────────────────────────────────────────────────
RAG_DEFAULT_TOP_K=12
RAG_MAX_TOP_K=50
RAG_BROAD_QUERY_TOP_K=16
RAG_INGESTION_WORKER_POLL_SECONDS=3
RAG_INGESTION_STALE_TIMEOUT_SECONDS=1800
RAG_SOURCE_LIMIT=12
RAG_CACHE_SEMANTIC_THRESHOLD=0.85  # 0.0-1.0; lower = more cache hits (but less precise)

# ── TurboQuant (Vector Quantization) ──────────────────────────────────────────
# int8 quantization still recommended even on 16GB — saves 4x storage in pgvector
# with only 98% accuracy cost. halfvec halves vector storage in Qdrant.
RAG_EMBEDDING_QUANTIZE=int8        # int8 = 4x storage compression, 98% accuracy
RAG_USE_HALFVEC=true               # halfvec (float16) in pgvector: 2x storage reduction

# ── Context Expansion ─────────────────────────────────────────────────────────
RAG_ENABLE_CONTEXT_EXPANSION=true   # Fetch neighboring chunks for context depth

# ── VRAM Tiering Guide (for other GPU sizes) ─────────────────────────────────
# 8GB  VRAM: OLLAMA_MODEL=llama3.1:8b          CONTEXT=32768  EMB=bge-small-en-v1.5
# 12GB VRAM: OLLAMA_MODEL=gemma3:12b           CONTEXT=49152  EMB=bge-large-en-v1.5
# 16GB VRAM: OLLAMA_MODEL=qwen2.5:14b          CONTEXT=65536  EMB=bge-large-en-v1.5  ← THIS
# 24GB VRAM: OLLAMA_MODEL=qwen2.5:32b-q4_K_M  CONTEXT=131072 EMB=bge-large-en-v1.5
# 48GB VRAM: OLLAMA_MODEL=llama3.3:70b-q4_K_M CONTEXT=131072 EMB=bge-large-en-v1.5
